{% extends "layouts/layout.twig" %}

{% block title %}
    Кабинет пользователя
{% endblock %}

{% block description %}

{% endblock %}

{% block content %}
    <div class="container pb-3 mb-12">
        <div class="row mt-3">
            <div class="col-md-10 col-sm-12 mt-5">
                <div class="d-flex justify-content-between align-items-center">
                    <h2>Мой кабинет</h2>

                    <a href="/auth/logout" class="btn btn-outline-secondary ">Выход</a>
                </div>
                <div class="mt-3">
                    <div class="input-group mb-3">
                        <span class="input-group-text">Ваш email:</span>
                        <span class="input-group-text">{{ email }}</span>
                    </div>

                    {% if subscribe.status == 'inactive' %}
                    <div class="input-group mb-3">
                        <span class="input-group-text">Доступное количество скачиваний:</span>
                        <span class="input-group-text">{{ profile.attempts }}</span>
                    </div>
                    {% endif %}
                    <div class="input-group mb-3">
                        <span class="input-group-text">Подписка:</span>
                            {% if subscribe.status == 'active' %}
                            <span class="input-group-text">Активна</span>
                            {% else %}
                                <span class="input-group-text">Не действует</span>
                                <span class="input-group-text">
                                    <a href="/payment/subscribe">Приобрести</a>
                                </span>
                            {% endif %}
                    </div>
                  <a href="https://t.me/help_ot_subscribe_bot" target="_blank">Получить комплект документации на 2025 год</a> (Более 190 документов ЛНА, 44 чек листа, 46 форм наряд допусков и образцов заполнения к ним).
                  <h4>Другие проекты:</h4>

                </div>




            </div>
        </div>
    </div>
{% endblock %}

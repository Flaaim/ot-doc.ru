{% extends "layouts/layout.twig" %}

{% block title %}
    Кабинет пользователя
{% endblock %}

{% block description %}

{% endblock %}

{% block content %}
    <div class="container pb-3 mb-12">
        <div class="row mt-3">
            <div class="col-md-10 col-sm-12 mt-5">
                <div class="d-flex justify-content-between align-items-center">
                    <h2>Мой кабинет</h2>

                    <a href="/auth/logout" class="btn btn-outline-secondary ">Выход</a>
                </div>
                <div class="mt-3">
                    <div class="input-group mb-3">
                        <span class="input-group-text">Ваш email:</span>
                        <span class="input-group-text">{{ email }}</span>
                    </div>

                    {% if not subscribe or subscribe.status != 'active' %}
                    <div class="input-group mb-3">
                        <span class="input-group-text">Доступное количество скачиваний:</span>
                        <span class="input-group-text fw-bold">{{ profile.attempts }}</span>
                    </div>
                    {% endif %}
                    <div class="input-group mb-3">
                        <span class="input-group-text">Статус подписки:</span>
                        {% if subscribe and subscribe.status == 'active' %}
                            <span class="input-group-text text-success fw-bold">Активна</span>
                            {% if subscribe.expires_at is null %}
                                <span class="input-group-text">Действует: ∞ (Навсегда)</span>
                            {% else %}
                                <span class="input-group-text">Действует до: {{ subscribe.expires_at|date('d.m.Y H:i') }}</span>
                            {% endif %}
                            <a href="/payment/subscribe" class="btn btn-outline-primary ms-2 align-self-center rounded">Продлить / Сменить тариф</a>
                        {% else %}
                            <span class="input-group-text text-danger fw-bold">Не действует</span>
                            <a href="/payment/subscribe" class="btn btn-primary ms-2 align-self-center rounded">Приобрести подписку</a>
                        {% endif %}
                    </div>
                </div>




            </div>
        </div>
    </div>
{% endblock %}
